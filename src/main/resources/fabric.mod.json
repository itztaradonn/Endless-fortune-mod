  "icon": "assets/endlessfortune/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": ["com.endless.fortune.EndlessFortune"],
    "client": ["com.endless.fortune.EndlessFortuneClient"]
  },
  "mixins": ["endlessfortune.mixins.json"],
  "depends": {
    "fabricloader": ">=0.18.0",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*"
  }
}
